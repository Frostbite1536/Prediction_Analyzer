# Limitless Exchange API key (generate at limitless.exchange -> profile -> Api keys)
LIMITLESS_API_KEY=lmts_your_api_key_here

# Polymarket (wallet address for public Data API)
POLYMARKET_WALLET=0xYourWalletAddress

# Kalshi (RSA key pair — generate at kalshi.com -> Settings -> API Keys)
KALSHI_API_KEY_ID=your_api_key_id
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
# KALSHI_DEMO=true  # Uncomment to use demo environment

# Manifold Markets (generate at manifold.markets -> Profile -> API key)
MANIFOLD_API_KEY=manifold_your_api_key_here

# FastAPI settings (for the local web app)
SECRET_KEY=change-this-secret-key-in-production
DATABASE_URL=sqlite:///./data/prediction_analyzer.db
